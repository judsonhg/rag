# ==== For NVIDIA AI WORKBENCH Users Only! ====
# Set environment variables in the format KEY=VALUE, 1 per line
# This file will be sourced inside the project container when started.
# NOTE: If you change this file while the project is running, you must restart the project container for changes to take effect.

# ==== Flag for AI Workbench env ====
AI_WORKBENCH=true

# ==== Default docker volumes ====
DATASET_ROOT=ingest

# ==== Set User for local NIM deployment ====
# USERID=$(id -u)

# ==== Endpoints for using on-prem NIMs ====
APP_LLM_SERVERURL=http://nim-llm:8000/v1
APP_EMBEDDINGS_SERVERURL=nemotron-vlm-embedding-ms:8000/v1
APP_RANKING_SERVERURL=nemotron-ranking-ms:8000
OCR_GRPC_ENDPOINT=nemotron-ocr:8001
OCR_HTTP_ENDPOINT=http://nemotron-ocr:8000/v1/infer
OCR_INFER_PROTOCOL=http
OCR_MODEL_NAME=pipeline
YOLOX_GRPC_ENDPOINT=page-elements:8001
YOLOX_INFER_PROTOCOL=http
YOLOX_GRAPHIC_ELEMENTS_GRPC_ENDPOINT=graphic-elements:8001
YOLOX_GRAPHIC_ELEMENTS_INFER_PROTOCOL=http
YOLOX_TABLE_STRUCTURE_GRPC_ENDPOINT=table-structure:8001
YOLOX_TABLE_STRUCTURE_INFER_PROTOCOL=http

# ==== Endpoints for using cloud NIMs ===
# APP_EMBEDDINGS_SERVERURL=""
# APP_RANKING_SERVERURL=""
# OCR_HTTP_ENDPOINT=https://ai.api.nvidia.com/v1/cv/nvidia/nemotron-ocr-v1
# OCR_INFER_PROTOCOL=http
# OCR_MODEL_NAME=pipeline
# YOLOX_HTTP_ENDPOINT=https://ai.api.nvidia.com/v1/cv/nvidia/nemotron-page-elements-v3
# YOLOX_INFER_PROTOCOL=http
# YOLOX_GRAPHIC_ELEMENTS_HTTP_ENDPOINT=https://ai.api.nvidia.com/v1/cv/nvidia/nemotron-graphic-elements-v1
# YOLOX_GRAPHIC_ELEMENTS_INFER_PROTOCOL=http
# YOLOX_TABLE_STRUCTURE_HTTP_ENDPOINT=https://ai.api.nvidia.com/v1/cv/nvidia/nemotron-table-structure-v1
# YOLOX_TABLE_STRUCTURE_INFER_PROTOCOL=http


# Set GPU IDs for local deployment
# ==== LLM ====
LLM_MS_GPU_ID=4
# Pair of empty H200s (vLLM uses 0,1,6)
NIM_PROFILE_ID=throughput

# ==== Embeddings ====
VLM_EMBEDDING_MS_GPU_ID=5

# ==== Reranker ====
RANKING_MS_GPU_ID=4

# ==== Vector DB GPU ID ====
VECTORSTORE_GPU_DEVICE_ID=7

# ==== Ingestion NIMs GPU ids ====
YOLOX_MS_GPU_ID=7
YOLOX_GRAPHICS_MS_GPU_ID=7
YOLOX_TABLE_MS_GPU_ID=7
OCR_MS_GPU_ID=7

# ==== Enable Accuracy Profile ====
# APP_NVINGEST_ENABLE_PAGED_DOC_SPLIT=False
# APP_NVINGEST_CHUNKSIZE=1024
# APP_NVINGEST_CHUNKOVERLAP=150
# ENABLE_RERANKER=True
# VECTOR_DB_TOPK=100

# ==== Enable Perf Profile ====
# APP_NVINGEST_ENABLE_PAGED_DOC_SPLIT=True
# APP_NVINGEST_CHUNKSIZE=512
# APP_NVINGEST_CHUNKOVERLAP=150
# ENABLE_RERANKER=False
# VECTOR_DB_TOPK=4
# APP_RETRIEVER_TOPK=10

# dgx: RAG GPUs avoid vLLM on 0,1,6

# 120B LLM on 2x H200 (GPUs 4,5) — vllm-fp8-tp2-pp1
NIM_MODEL_PROFILE=a89dbe9ec9ba8b77837d6c9586bde67a261c66fc8cac454b06f9eb93ff7ebbd2
LLM_CUDA_VISIBLE_DEVICES=4,5
LLM_MS_GPU_ID=4
LLM_MS_GPU_ID2=5

# dgx: nim-llm aliases vllm-gpt-oss-120b — only gpt-oss-120b exists (not Nemotron NIM)
APP_LLM_MODELNAME=gpt-oss-120b
APP_QUERYREWRITER_MODELNAME=gpt-oss-120b
APP_QUERYREWRITER_SERVERURL=http://nim-llm:8000/v1
SUMMARY_LLM=gpt-oss-120b
SUMMARY_LLM_SERVERURL=nim-llm:8000
REFLECTION_LLM=gpt-oss-120b
REFLECTION_LLM_SERVERURL=http://nim-llm:8000/v1
AGENTIC_PLANNER_LLM_MODEL=gpt-oss-120b
AGENTIC_PLANNER_LLM_SERVERURL=http://nim-llm:8000/v1
AGENTIC_TASK_LLM_MODEL=gpt-oss-120b
AGENTIC_TASK_LLM_SERVERURL=http://nim-llm:8000/v1
AGENTIC_SEED_GEN_LLM_MODEL=gpt-oss-120b
AGENTIC_SEED_GEN_LLM_SERVERURL=http://nim-llm:8000/v1
AGENTIC_SYNTHESIS_LLM_MODEL=gpt-oss-120b
AGENTIC_SYNTHESIS_LLM_SERVERURL=http://nim-llm:8000/v1
# On-prem HTTP endpoints for NIMs (avoid gRPC TLS mismatch with local Triton)
YOLOX_HTTP_ENDPOINT=http://page-elements:8000/v1/infer
YOLOX_GRAPHIC_ELEMENTS_HTTP_ENDPOINT=http://graphic-elements:8000/v1/infer
YOLOX_TABLE_STRUCTURE_HTTP_ENDPOINT=http://table-structure:8000/v1/infer

# Standalone images (PNG/JPEG): use document-level extraction so OCR runs on the full image
APP_NVINGEST_TEXTDEPTH=document
APP_NVINGEST_EXTRACTPAGEASIMAGE=True
INGEST_LOG_LEVEL=INFO
APP_NVINGEST_PDFEXTRACTMETHOD=ocr
NEMOTRON_OCR_IMAGE=nvcr.io/nim/nvidia/nemotron-ocr-v2
NEMOTRON_OCR_TAG=1.4.0
NIM_OCR_MODEL_VERSION=v2

# Nemotron OCR v2 multilingual: EN + Chinese (Simplified/Traditional) + Korean + Japanese + Russian
# NIM_OCR_MODEL_VERSION=v2 (default multilingual). Use v2-en for English-only.
